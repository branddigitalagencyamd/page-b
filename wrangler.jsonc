{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "page",
  "main": "src/index.ts",
  "compatibility_date": "2025-10-31",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "page",
      "database_id": ""
    }
  ],
  "vars": {
    "JWT_SECRET": "",
    "APP_ENV": "development"          
  }
}
